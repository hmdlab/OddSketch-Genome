{
  "paths": {
    "outdir": "outputs/default"
  },
  "make_genomes": {
    "genome_length": 1000000,
    "num_pairs": 10,
    "mutation_min": 10,
    "mutation_max": 5000,
    "seed_base": 2000
  },
  "true_jaccard": {
    "kmerlen": 64
  },
  "oddsketch": {
    "threads": 8,
    "kmerlen": 64,
    "sketch_size": 2048,
    "j0": 0.9,
    "pos_mode": "mix",
    "canonical": true
  },
  "bindash": {
    "enabled": true,
    "bindash_bin": "bindash",
    "threads": 8,
    "mode": "sketch_dist",
    "kmerlen": 64,
    "sketch_size": 2048,
    "bbits": 16,
    "pair_cmd": "{bin} exact --nthreads={threads} {f1} {f2}"
  }
}
